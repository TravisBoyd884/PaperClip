# PaperClip Agent Demo — LLM API Keys
# Copy this to .agents.env and fill in your keys.
# At least one key is required; agents without keys are skipped.

# Agent 1: Anthropic Claude
ANTHROPIC_API_KEY=

# Agent 2: OpenAI GPT
OPENAI_API_KEY=

# Agent 3: Google Gemini
GOOGLE_AI_API_KEY=

# Agent 4: Groq (Llama)
GROQ_API_KEY=

# Optional: override demo user credentials (defaults match seed-data.json)
# AGENT_1_EMAIL=agent1@paperclip.demo
# AGENT_1_PASSWORD=paperclip-demo-agent-1
# AGENT_2_EMAIL=agent2@paperclip.demo
# AGENT_2_PASSWORD=paperclip-demo-agent-2
# AGENT_3_EMAIL=agent3@paperclip.demo
# AGENT_3_PASSWORD=paperclip-demo-agent-3
# AGENT_4_EMAIL=agent4@paperclip.demo
# AGENT_4_PASSWORD=paperclip-demo-agent-4
